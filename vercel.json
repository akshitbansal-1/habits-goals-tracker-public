{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/items/:id", "destination": "/api/items?id=:id" },
    { "source": "/api/goals/:id", "destination": "/api/goals?id=:id" },
    { "source": "/api/notes/:id", "destination": "/api/notes?id=:id" },
    { "source": "/api/folders/:id", "destination": "/api/folders?id=:id" },
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
